                "value": { "percentage": { "value": 10 } }
              },
              {
                "message": "20% off (upsell)",
                "targets": [{ "cartLine": { "id": "gid://shopify/CartLine/1" } }],
                "value": { "percentage": { "value": 20 } }
              }
            ],
            "selectionStrategy": "ALL"
          }
        }
      ]
    }
  }
}
